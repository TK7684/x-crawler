[Unit]
Description=X Scraper Daemon
After=network-online.target

[Service]
Type=simple
User=tk578
WorkingDirectory=/home/tk578/.openclaw/workspace/x-scraper
ExecStart=/home/tk578/.openclaw/workspace/x-scraper/venv/bin/python3 -u /home/tk578/.openclaw/workspace/x-scraper/run_scheduler.py --daemon
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
